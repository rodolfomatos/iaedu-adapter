# Variáveis de Ambiente para IAEDU Adapter
# Copie este arquivo para .env e preencha com seus valores

# OBRIGATÓRIO: Chave API da iaedu.pt
# Forneça via header x-iaedu-api-key ou x-api-key, ou defina aqui
IAEDU_API_KEY=sua_chave_api_aqui

# OPCIONAL: Channel ID (pode ser sobrescrito por header x-iaedu-channel-id)
IAEDU_CHANNEL_ID=cmh0rfgmn0i64j801uuoletwy

# OPCIONAL: Agent ID (pode ser sobrescrito por header x-iaedu-agent-id)
IAEDU_AGENT_ID=cmamvd3n40000c801qeacoad2

# CONFIGURAÇÃO DO SERVIDOR
ADAPTER_PORT=4000
SERVER_HOST=0.0.0.0
MODEL_NAME=iaedu-custom
REQUEST_TIMEOUT_MS=60000
LOG_LEVEL=info

# EXEMPLOS DE VALORES COMUNS:
# IAEDU_API_KEY=seu_api_key_aqui
# IAEDU_CHANNEL_ID=cmh0rfgmn0i64j801uuoletwy
# IAEDU_AGENT_ID=cmamvd3n40000c801qeacoad2
# ADAPTER_PORT=4000
# SERVER_HOST=0.0.0.0
# MODEL_NAME=iaedu-custom
# REQUEST_TIMEOUT_MS=60000
# LOG_LEVEL=info