# Variáveis de ambiente para o iaedu-adapter
# Copia este ficheiro para .env e preenche os valores

# Chave API da iaedu.pt (OBRIGATÓRIO)
IAEDU_API_KEY=sk-usr-YOUR_KEY_HERE

# Endpoint da API (opcional — tem valor hardcoded em adapter-server.mjs)
# IAEDU_ENDPOINT=https://api.iaedu.pt/agent-chat/api/v1/agent/cmamvd3n40000c801qeacoad2/stream

# Porta do adapter (opcional — default: 4000)
# ADAPTER_PORT=4000